{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "panelists": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tool": {
            "type": "string",
            "enum": [
              "claude",
              "opencode",
              "pi"
            ]
          },
          "model": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "icon": {
            "type": "string"
          },
          "systemPrompt": {
            "type": "string"
          },
          "promptFile": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "active": {
            "type": "boolean"
          }
        },
        "required": [
          "tool",
          "label",
          "id"
        ],
        "additionalProperties": false
      }
    },
    "judge": {
      "type": "object",
      "properties": {
        "tool": {
          "type": "string",
          "enum": [
            "claude",
            "opencode",
            "pi"
          ]
        },
        "model": {
          "type": "string"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "icon": {
          "type": "string"
        },
        "systemPrompt": {
          "type": "string"
        },
        "promptFile": {
          "type": "string"
        }
      },
      "required": [
        "tool",
        "label"
      ],
      "additionalProperties": false
    },
    "validator": {
      "type": "object",
      "properties": {
        "tool": {
          "type": "string",
          "enum": [
            "claude",
            "opencode",
            "pi"
          ]
        },
        "model": {
          "type": "string"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "icon": {
          "type": "string"
        },
        "systemPrompt": {
          "type": "string"
        },
        "promptFile": {
          "type": "string"
        }
      },
      "required": [
        "tool",
        "label"
      ],
      "additionalProperties": false
    },
    "forge": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "github",
            "gitlab",
            "gitea",
            "azure",
            "manual"
          ]
        },
        "baseUrl": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "tokenEnv": {
          "type": "string"
        },
        "remote": {
          "type": "string"
        },
        "cli": {
          "type": "boolean"
        }
      },
      "required": [
        "provider"
      ],
      "additionalProperties": false
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "install": {
          "type": "string"
        },
        "build": {
          "type": "string"
        },
        "test": {
          "type": "string"
        },
        "run": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "timeoutMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "panelists",
    "judge",
    "validator"
  ],
  "additionalProperties": false
}
