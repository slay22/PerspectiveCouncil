# ── CLI Tools (configure each tool separately — no API keys here) ─────────────
#
# Claude Code (Security Architect + Validator):
#   claude config set model claude-opus-4-5
#
# OpenCode (Code Quality Analyst):
#   opencode auth login   → select your provider + model
#
# Pi Agent (Systems Designer + Judge):
#   pi             → then /model to pick your model
#
# ── Telegram (optional) ───────────────────────────────────────────────────────
#
# 1. Message @BotFather → /newbot → paste token here
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
#
# 2. Your chat ID — get it from @userinfobot
TELEGRAM_ALLOWED_CHATS=123456789
#
# ── Web server (optional) ─────────────────────────────────────────────────────
#
# Host to bind the GUI/API to. Defaults to 127.0.0.1 (loopback only).
# Set to 0.0.0.0 only if you deliberately want it reachable from other hosts.
# COUNCIL_HOST=127.0.0.1
#
# Bearer token guarding ALL HTTP endpoints (including GET /api/state) and the
# WebSocket. The browser UI is given the token automatically. Leave unset for
# loopback-only local use. A non-loopback bind REQUIRES this — the app refuses
# to start otherwise. Generate one with: openssl rand -hex 16
COUNCIL_API_TOKEN=change-me
#
# When exposing on the network, also set:
# COUNCIL_HOST=0.0.0.0
#
# ── Forge (PR/MR hosting) ─────────────────────────────────────────────────────
#
# The forge is chosen in panelists.json (or the Config tab). When the platform
# CLI isn't installed, the REST API is used with a token from one of these.
# Only set the one matching your configured provider:
# GITHUB_TOKEN=ghp_...
# GITLAB_TOKEN=glpat-...
# GITEA_TOKEN=...                  # Codeberg / Forgejo / Gitea
# AZURE_DEVOPS_EXT_PAT=...         # Azure DevOps PAT
